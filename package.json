{
  "name": "allquiet-status-widget",
  "version": "1.0.0",
  "private": true,
  "description": "Self-contained status popup widget for AllQuiet status pages. One script tag, no dependencies.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/pixelunioneu/allquiet-status-widget"
  },
  "scripts": {
